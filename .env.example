# 本文件仅作说明。实际上游 Xboard 使用其自身 .env。
# 部署官方 Xboard 后，在 XBOARD 目录配置：

APP_NAME=FreeChina
APP_URL=https://your-domain.com

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=xboard
DB_USERNAME=xboard
DB_PASSWORD=change_me

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# 支付相关请在「管理后台 → 支付配置」填写，勿写入仓库：
# - Jeepay gateway / mchNo / appId / appSecret
# - TokenPay URL / API Token
